@model ComplectGroup.Web.Models.Account.UserWithPermissionsViewModel
@{
    ViewData["Title"] = "Редактирование пользователя";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>✏️ Редактирование пользователя</h1>
        <a asp-action="Users" class="btn btn-secondary">← Назад к списку</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="EditUser" method="post">
        <input type="hidden" asp-for="Id" />
        
        <div class="row">
            <!-- Основная информация -->
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📋 Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">ФИО</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedRole" class="form-label">Роль</label>
                            <select asp-for="SelectedRole" asp-items="@(new SelectList(Model.AvailableRoles))" class="form-select">
                                <option value="">-- Выберите роль --</option>
                            </select>
                            <small class="text-muted">Роль определяет права по умолчанию</small>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Активен</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Права доступа -->
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">🔑 Права доступа</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">
                            Отметьте права, которые будут назначены пользователю. 
                            Права из разных категорий могут комбинироваться.
                        </p>
                        
                        @foreach (var category in Model.PermissionsByCategory)
                        {
                            <div class="mb-4">
                                <h6 class="border-bottom pb-2">@category.Key</h6>
                                <div class="row">
                                    @foreach (var permission in category.Value)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input permission-checkbox" 
                                                       type="checkbox" 
                                                       name="SelectedPermissions" 
                                                       value="@permission.Name" 
                                                       id="@permission.Name"
                                                       @(Model.SelectedPermissions.Contains(permission.Name) ? "checked" : "") />
                                                <label class="form-check-label" for="@permission.Name">
                                                    <strong>@permission.DisplayName</strong>
                                                    <br />
                                                    <small class="text-muted">@permission.Description</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">💾 Сохранить изменения</button>
            <a asp-action="Users" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Подсветка выбранных прав
        document.querySelectorAll('.permission-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                this.closest('.form-check').classList.toggle('bg-light', this.checked);
            });
            // Инициализация при загрузке
            if (checkbox.checked) {
                checkbox.closest('.form-check').classList.add('bg-light');
            }
        });
    </script>
}
