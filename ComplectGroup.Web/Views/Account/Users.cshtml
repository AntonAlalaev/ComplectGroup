@using ComplectGroup.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@model List<ApplicationUser>
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>👥 Управление пользователями</h1>
        <a asp-action="CreateUser" class="btn btn-success">➕ Добавить пользователя</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card">
        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Имя</th>
                        <th>Роли</th>
                        <th>Права</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.FullName</td>
                            <td>
                                @{
                                    var roles = await UserManager.GetRolesAsync(user);
                                }
                                @if (roles.Any())
                                {
                                    @foreach (var role in roles)
                                    {
                                        <span class="badge bg-primary me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var claims = await UserManager.GetClaimsAsync(user);
                                    var permissions = claims.Where(c => c.Type == "Permission").Select(c => c.Value).ToList();
                                }
                                @if (permissions.Any())
                                {
                                    <span class="badge bg-info text-dark" title="@string.Join(", ", permissions)">
                                        🔑 @permissions.Count
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Неактивен</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="Редактировать">✏️</a>
                                <button type="button" class="btn btn-sm btn-outline-success" title="Права доступа" 
                                        onclick="openPermissionsModal('@user.Id', '@user.Email?.Replace("'", "\\'")')">🔑</button>
                                @if (user.Email != "admin@complectgroup.com")
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Удалить пользователя @user.Email?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Модальное окно для редактирования прав -->
<div class="modal fade" id="permissionsModal" tabindex="-1" aria-labelledby="permissionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div id="permissionsModalContent">
                <!-- Загрузка... -->
                <div class="modal-body text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-2">Загрузка прав доступа...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPermissionsModal(userId, userEmail) {
            const modal = new bootstrap.Modal(document.getElementById('permissionsModal'));
            document.getElementById('permissionsModalLabel')?.remove();
            
            // Показываем индикатор загрузки
            fetch('/Account/EditPermissions/' + userId)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('permissionsModalContent').innerHTML = html;
                    modal.show();
                })
                .catch(error => {
                    console.error('Ошибка:', error);
                    document.getElementById('permissionsModalContent').innerHTML = 
                        '<div class="modal-body text-danger">Ошибка при загрузке прав</div>';
                    modal.show();
                });
        }
    </script>
}