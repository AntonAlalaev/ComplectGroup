@model ComplectGroup.Web.Models.Account.CreateUserViewModel

@{
    ViewData["Title"] = "Создание пользователя";
}

<div class="container mt-4">
    <h1>➕ @ViewData["Title"]</h1>
    
    <div class="card">
        <div class="card-body">
            <form asp-action="CreateUser" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">Полное имя</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">Подтвердите пароль</label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Роли</label>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <div class="form-check">
                            <!-- ✅ ИСПРАВЛЕНО: используем name вместо asp-for -->
                            <input class="form-check-input" type="checkbox" 
                                   name="SelectedRoles" 
                                   value="@role" 
                                   id="role-@role" />
                            <label class="form-check-label" for="role-@role">@role</label>
                        </div>
                    }
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Создать</button>
                    <a asp-action="Users" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}