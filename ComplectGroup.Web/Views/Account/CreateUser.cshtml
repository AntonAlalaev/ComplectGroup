@model ComplectGroup.Web.Models.Account.UserWithPermissionsViewModel
@{
    ViewData["Title"] = "Создание пользователя";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>➕ Создание пользователя</h1>
        <a asp-action="Users" class="btn btn-secondary">← Назад к списку</a>
    </div>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form asp-action="CreateUser" method="post">
        <div class="row">
            <!-- Основная информация -->
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📋 Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email *</label>
                            <input asp-for="Email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">ФИО *</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Пароль *</label>
                            <input asp-for="Password" class="form-control" required minlength="6" />
                            <small class="text-muted">Минимум 6 символов</small>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Подтверждение пароля *</label>
                            <input asp-for="ConfirmPassword" class="form-control" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedRole" class="form-label">Роль</label>
                            <select asp-for="SelectedRole" asp-items="@(new SelectList(Model.AvailableRoles))" class="form-select">
                                <option value="">-- Выберите роль --</option>
                            </select>
                            <small class="text-muted">Права роли будут применены по умолчанию</small>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" class="form-check-input" checked />
                            <label asp-for="IsActive" class="form-check-label">Активен</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Права доступа -->
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">🔑 Права доступа</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">
                            Отметьте дополнительные права, которые будут назначены пользователю.
                            Вы можете выбрать любые права независимо от выбранной роли.
                        </p>
                        
                        @foreach (var category in Model.PermissionsByCategory)
                        {
                            <div class="mb-4">
                                <h6 class="border-bottom pb-2">@category.Key</h6>
                                <div class="row">
                                    @foreach (var permission in category.Value)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input permission-checkbox" 
                                                       type="checkbox" 
                                                       name="SelectedPermissions" 
                                                       value="@permission.Name" 
                                                       id="@permission.Name" />
                                                <label class="form-check-label" for="@permission.Name">
                                                    <strong>@permission.DisplayName</strong>
                                                    <br />
                                                    <small class="text-muted">@permission.Description</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="alert alert-info mt-3">
                            <strong>💡 Совет:</strong> 
                            Выберите роль, чтобы автоматически применить права по умолчанию, 
                            затем при необходимости добавьте или уберите отдельные права.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">✅ Создать пользователя</button>
            <a asp-action="Users" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Подсветка выбранных прав
        document.querySelectorAll('.permission-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                this.closest('.form-check').classList.toggle('bg-light', this.checked);
            });
        });

        // Автоматическое применение прав роли при выборе
        document.querySelector('select[name="SelectedRole"]')?.addEventListener('change', function() {
            const roleName = this.value;
            // Здесь можно добавить логику для автоматического выбора прав по роли
            // Но для гибкости мы оставляем выбор за администратором
        });
    </script>
}
