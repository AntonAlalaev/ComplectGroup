@using ComplectGroup.Web.Models
@model ComplectationBrowseViewModel
@{
    ViewData["Title"] = "Просмотр комплектации";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-primary">Список</a>
        <a asp-action="Import" class="btn btn-success me-2">📊 Excel</a>
        <a asp-action="ReportByDates" class="btn btn-primary">Сводная таблица</a>
        <a asp-action="Browse" class="btn btn-secondary">Просмотр</a>
    </div>

    <!-- === Кнопка фильтра === -->
    <div class="mb-3">
        @if (Model.SelectedComplectation != null)
        {
            <form method="get" action="@Url.Action("Browse")" style="display: inline;">
                <input type="hidden" name="id" value="@Model.SelectedComplectation.Id" />
                @if (Model.ShowOnlyDeficit)
                {
                    <input type="hidden" name="showOnlyDeficit" value="false" />
                    <button type="submit" class="btn btn-warning">
                        ✓ Только с дефицитом (отключить фильтр)
                    </button>
                }
                else
                {
                    <input type="hidden" name="showOnlyDeficit" value="true" />
                    <button type="submit" class="btn btn-outline-warning">
                        Только с дефицитом
                    </button>
                }
            </form>
        }
    </div>

    <!-- === Выбор комплектации (НОВЫЙ UI) === -->
    <div class="mb-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">📦 Выбранная комплектация</h5>
            </div>
            <div class="card-body">
                @if (Model.SelectedComplectation != null)
                {
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <div class="d-flex align-items-center gap-3">
                                <div>
                                    <h4 class="mb-1">@Model.SelectedComplectation.Number</h4>
                                    <p class="text-muted mb-0">@Model.SelectedComplectation.Customer</p>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <div class="small text-muted">Дата отгрузки</div>
                                    <div class="fw-bold">@Model.SelectedComplectation.ShippingDate.ToString("dd.MM.yyyy")</div>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <div class="small text-muted">Менеджер</div>
                                    <div class="fw-bold">@Model.SelectedComplectation.Manager</div>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <div class="small text-muted">Статус</div>
                                    <div>
                                        @{
                                            var statusClass = Model.SelectedComplectation.Status switch
                                            {
                                                0 => "bg-warning text-dark",
                                                1 => "bg-info text-white",
                                                2 => "bg-success text-white",
                                                3 => "bg-secondary text-white",
                                                _ => "bg-secondary text-white"
                                            };
                                            var statusText = Model.SelectedComplectation.Status switch
                                            {
                                                0 => "📝 Черновик",
                                                1 => "📦 Частично",
                                                2 => "✅ Отгружена",
                                                3 => "🗄️ Архив",
                                                _ => "Неизвестно"
                                            };
                                        }
                                        <span class="badge @statusClass">@statusText</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 text-end">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#complectationPickerModal">
                                🔍 Изменить выбор
                            </button>
                            <div class="small text-muted mt-1">
                                Позиций: @Model.SelectedComplectation.Positions.Count
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-3">Комплектация не выбрана</p>
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#complectationPickerModal">
                            🔍 Выбрать комплектацию
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Model.SelectedComplectation != null)
    {
        <h3>@Model.SelectedComplectation.Number - @Model.SelectedComplectation.Customer</h3>
        <p class="text-muted">
            Дата отгрузки: @Model.SelectedComplectation.ShippingDate.ToString("dd.MM.yyyy"),
            Менеджер: @Model.SelectedComplectation.Manager
        </p>

        @if (Model.PositionDetails.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Раздел</th>
                            <th>Деталь</th>
                            <th class="text-center">Количество</th>
                            <th class="text-center bg-success text-white">На складе</th>
                            <th class="text-center bg-info text-white">Отгружено</th>
                            <th class="text-center bg-warning text-dark">Надо отгрузить</th>
                            <th class="text-center bg-danger text-white">Дефицит</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.PositionDetails)
                        {
                            string deficitClass = "text-center ";
                            if (row.Deficit == 0)
                                deficitClass += "bg-success text-white";
                            else if (row.Deficit > 0)
                                deficitClass += "bg-danger text-white";
                            else
                                deficitClass += "bg-info text-white";

                            string warehouseClass = "text-center ";
                            if (row.WarehouseQuantity == 0)
                                warehouseClass += "bg-danger text-white";
                            else if (row.WarehouseQuantity < row.RemainingToShip)
                                warehouseClass += "bg-warning text-dark";
                            else
                                warehouseClass += "bg-success text-white";

                            <tr>
                                <td>@row.Chapter</td>
                                <td>@row.PartName</td>
                                <td class="text-center"><strong>@row.RequiredQuantity</strong></td>
                                <td class="@warehouseClass"><strong>@row.WarehouseQuantity</strong></td>
                                <td class="text-center bg-info text-white"><strong>@row.ShippedQuantity</strong></td>
                                <td class="text-center bg-warning text-dark"><strong>@row.RemainingToShip</strong></td>
                                <td class="@deficitClass"><strong>@row.Deficit</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="mt-2">
                @if (Model.ShowOnlyDeficit)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-filter"></i> Показаны только позиции с дефицитом.
                        Всего позиций: @Model.PositionDetails.Count
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">
                @if (Model.ShowOnlyDeficit)
                {
                    <p><i class="bi bi-emoji-frown"></i> Нет позиций с дефицитом в этой комплектации.</p>
                }
                else
                {
                    <p><i class="bi bi-inbox"></i> Нет позиций в этой комплектации.</p>
                }
            </div>
        }
    }
    else
    {
        <p class="text-muted">Выберите комплектацию для просмотра</p>
    }
</div>

<!-- Подключение модального окна выбора комплектации -->
@await Html.PartialAsync("_ComplectationPicker")

@section Scripts {
    <script>
        // Скрипт для модального окна выбора комплектации находится в _ComplectationPicker.cshtml
    </script>
}