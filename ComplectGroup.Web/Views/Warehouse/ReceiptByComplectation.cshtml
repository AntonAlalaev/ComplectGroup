@using ComplectGroup.Web.Models
@model ComplectationReceiptViewModel

@{
    ViewData["Title"] = "Приходование по комплектации";
}

<h1>@ViewData["Title"]</h1>

<!-- Сообщения об ошибках/успехе -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Форма -->
<form method="post" id="receiptForm">
    @Html.AntiForgeryToken()

    <!-- Выбор комплектации -->
    <div class="mb-4">
        <label class="form-label"><strong>Выберите комплектацию:</strong></label>
        <div class="card">
            <div class="card-body">
                <div id="selectedComplectationDisplay" style="display: none;">
                    <div class="row align-items-center">
                        <div class="col-md-10">
                            <div class="d-flex align-items-center gap-3">
                                <div>
                                    <h5 class="mb-1" id="selectedComplectationNumber"></h5>
                                    <p class="text-muted mb-0" id="selectedComplectationCustomer"></p>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <div class="small text-muted">Дата отгрузки</div>
                                    <div class="fw-bold" id="selectedComplectationDate"></div>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <div class="small text-muted">Менеджер</div>
                                    <div class="fw-bold" id="selectedComplectationManager"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 text-end">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#complectationPickerModal">
                                🔍 Изменить
                            </button>
                        </div>
                    </div>
                </div>
                <div id="noComplectationSelected" class="text-center py-3">
                    <p class="text-muted mb-3">Комплектация не выбрана</p>
                    <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#complectationPickerModal">
                        🔍 Выбрать комплектацию
                    </button>
                </div>
                <!-- Скрытый input для хранения ID выбранной комплектации -->
                <input type="hidden" id="SelectedComplectationId" name="SelectedComplectationId" value="" />
            </div>
        </div>
    </div>

    <!-- Таблица позиций -->
    <div id="lineItemsContainer" style="display: none;">
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-light">
                    <tr>
                        <th>Раздел</th>
                        <th>Деталь</th>
                        <th class="text-center">Требуемо в комплектации</th>
                        <th class="text-center">Оприходовать (кол-во)</th>
                    </tr>
                </thead>
                <tbody id="lineItemsBody">
                    <!-- Заполняется динамически -->
                </tbody>
            </table>
        </div>

        <!-- Кнопка -->
        <div class="mt-4">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fas fa-check-circle"></i> Оприходовать
            </button>
            <a href="@Url.Action("Index", "Warehouse")" class="btn btn-secondary btn-lg">
                <i class="fas fa-times-circle"></i> Отмена
            </a>
        </div>
    </div>
</form>

<!-- Подключение модального окна выбора комплектации -->
@await Html.PartialAsync("_WarehouseComplectationPicker")

<!-- JavaScript для загрузки позиций -->
<script>
    // Глобальные переменные для хранения состояния
    let pickerState = {
        pageNumber: 1,
        pageSize: 20,
        selectedId: null
    };

    let searchTimeout = null;

    // Debounce для поиска (задержка 300мс)
    function debounceSearch() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(searchComplectations, 300);
    }

    // Применение пресета
    function applyPreset(preset) {
        // Сброс всех фильтров
        document.getElementById('filterNumber').value = '';
        document.getElementById('filterCustomer').value = '';
        document.getElementById('filterManager').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterDateFrom').value = '';
        document.getElementById('filterDateTo').value = '';

        // Установка пресета
        const today = new Date().toISOString().split('T')[0];

        switch(preset) {
            case 'today':
                document.getElementById('filterDateFrom').value = today;
                document.getElementById('filterDateTo').value = today;
                break;
            case 'week':
                const startOfWeek = getStartOfWeek(new Date());
                document.getElementById('filterDateFrom').value = startOfWeek;
                document.getElementById('filterDateTo').value = today;
                break;
            case 'month':
                const startOfMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().split('T')[0];
                document.getElementById('filterDateFrom').value = startOfMonth;
                document.getElementById('filterDateTo').value = today;
                break;
            case 'draft':
                document.getElementById('filterStatus').value = '0';
                break;
            case 'shipped':
                document.getElementById('filterStatus').value = '2';
                break;
        }

        searchComplectations();
    }

    // Получить начало недели (понедельник)
    function getStartOfWeek(date) {
        const day = date.getDay();
        const diff = date.getDate() - day + (day === 0 ? -6 : 1);
        return new Date(date.setDate(diff)).toISOString().split('T')[0];
    }

    // Сброс фильтров
    function resetFilters() {
        document.getElementById('filterNumber').value = '';
        document.getElementById('filterCustomer').value = '';
        document.getElementById('filterManager').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterDateFrom').value = '';
        document.getElementById('filterDateTo').value = '';
        document.getElementById('filterPageSize').value = '20';
        pickerState.pageNumber = 1;
        pickerState.pageSize = 20;
        searchComplectations();
    }

    // Поиск комплектаций
    async function searchComplectations() {
        pickerState.pageSize = parseInt(document.getElementById('filterPageSize').value);

        const params = new URLSearchParams({
            pageNumber: pickerState.pageNumber.toString(),
            pageSize: pickerState.pageSize.toString(),
            searchNumber: document.getElementById('filterNumber').value || '',
            searchCustomer: document.getElementById('filterCustomer').value || '',
            searchManager: document.getElementById('filterManager').value || '',
            status: document.getElementById('filterStatus').value || '',
            dateFrom: document.getElementById('filterDateFrom').value || '',
            dateTo: document.getElementById('filterDateTo').value || ''
        });

        const url = `/api/complectations/search?${params}`;
        console.log('API запрос:', url);

        try {
            const response = await fetch(url);
            console.log('Статус ответа:', response.status);

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log('Получены данные:', data);

            renderResults(data);
            renderPagination(data);
            document.getElementById('totalCount').textContent = data.totalCount;
        } catch (error) {
            console.error('Ошибка поиска:', error);
            document.getElementById('pickerResults').innerHTML = `
                <tr>
                    <td colspan="8" class="text-center text-danger py-4">
                        ❌ Ошибка загрузки данных: ${error.message}
                    </td>
                </tr>
            `;
        }
    }

    // Отрисовка результатов
    function renderResults(data) {
        const tbody = document.getElementById('pickerResults');

        if (data.items.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        😕 Ничего не найдено
                    </td>
                </tr>
            `;
            return;
        }

        const statusLabels = {
            0: { text: '📝 Черновик', class: 'bg-warning text-dark' },
            1: { text: '📦 Частично', class: 'bg-info text-white' },
            2: { text: '✅ Отгружена', class: 'bg-success text-white' },
            3: { text: '🗄️ Архив', class: 'bg-secondary text-white' }
        };

        tbody.innerHTML = data.items.map(item => {
            const status = statusLabels[item.status] || statusLabels[0];
            const isSelected = item.id === pickerState.selectedId;
            const rowClass = isSelected ? 'table-primary' : '';

            return `
                <tr class="${rowClass}" style="cursor: pointer;" onclick="selectComplectation(${item.id}, '${escapeHtml(item.number)}', '${escapeHtml(item.customer || '')}', '${formatDate(item.shippingDate)}', '${escapeHtml(item.manager || '')}')">
                    <td><strong>${item.number}</strong></td>
                    <td>${item.customer || '—'}</td>
                    <td>${item.manager || '—'}</td>
                    <td>${formatDate(item.shippingDate)}</td>
                    <td class="text-center"><span class="badge ${status.class}">${status.text}</span></td>
                    <td class="text-center">${item.positions?.length || 0}</td>
                    <td class="text-end">${item.totalWeight?.toFixed(0) || 0}</td>
                    <td class="text-end">${item.totalVolume?.toFixed(2) || 0}</td>
                </tr>
            `;
        }).join('');
    }

    // Отрисовка пагинации
    function renderPagination(data) {
        const pagination = document.getElementById('pickerPagination');

        if (data.totalPages <= 1) {
            pagination.innerHTML = '';
            return;
        }

        let html = `
            <li class="page-item ${!data.hasPrevious ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${data.pageNumber - 1}); return false;">← Назад</a>
            </li>
        `;

        // Первая страница
        if (data.pageNumber > 3) {
            html += `<li class="page-item"><a class="page-link" href="#" onclick="goToPage(1); return false;">1</a></li>`;
            if (data.pageNumber > 4) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }

        // Текущая и соседние страницы
        for (let i = Math.max(1, data.pageNumber - 2); i <= Math.min(data.totalPages, data.pageNumber + 2); i++) {
            if (i === data.pageNumber) {
                html += `<li class="page-item active"><a class="page-link" href="#">${i}</a></li>`;
            } else {
                html += `<li class="page-item"><a class="page-link" href="#" onclick="goToPage(${i}); return false;">${i}</a></li>`;
            }
        }

        // Последняя страница
        if (data.pageNumber < data.totalPages - 2) {
            if (data.pageNumber < data.totalPages - 3) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
            html += `<li class="page-item"><a class="page-link" href="#" onclick="goToPage(${data.totalPages}); return false;">${data.totalPages}</a></li>`;
        }

        html += `
            <li class="page-item ${!data.hasNext ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${data.pageNumber + 1}); return false;">Вперёд →</a>
            </li>
        `;

        pagination.innerHTML = html;
    }

    // Переход на страницу
    function goToPage(page) {
        pickerState.pageNumber = page;
        searchComplectations();
    }

    // Выбор комплектации
    function selectComplectation(id, number, customer, date, manager) {
        // Устанавливаем значения в скрытый input
        document.getElementById('SelectedComplectationId').value = id;
        
        // Обновляем отображение выбранной комплектации
        document.getElementById('selectedComplectationNumber').textContent = number;
        document.getElementById('selectedComplectationCustomer').textContent = customer || '—';
        document.getElementById('selectedComplectationDate').textContent = date;
        document.getElementById('selectedComplectationManager').textContent = manager || '—';
        
        // Показываем панель выбранной комплектации, скрываем кнопку выбора
        document.getElementById('selectedComplectationDisplay').style.display = 'block';
        document.getElementById('noComplectationSelected').style.display = 'none';
        
        // Закрываем модальное окно
        const modal = bootstrap.Modal.getInstance(document.getElementById('complectationPickerModal'));
        if (modal) {
            modal.hide();
        }
        
        // Загружаем позиции комплектации
        loadComplectationPositions(id);
        
        console.log('Выбрана комплектация:', id, number);
    }

    // Экранирование HTML-символов
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Форматирование даты
    function formatDate(dateStr) {
        if (!dateStr) return '—';
        const date = new Date(dateStr);
        return date.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    // Загрузка при открытии модального окна
    document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('complectationPickerModal');
        modal.addEventListener('shown.bs.modal', function() {
            searchComplectations();
        });
    });

    // Функция для загрузки позиций комплектации
    function loadComplectationPositions(complectationId) {
        if (!complectationId) {
            document.getElementById('lineItemsContainer').style.display = 'none';
            return;
        }

        // AJAX запрос для получения позиций
        fetch(`/Warehouse/GetComplectationPositions/${complectationId}`)
            .then(response => {
                if (!response.ok) throw new Error('Ошибка загрузки');
                return response.json();
            })
            .then(data => {
                renderLineItems(data);
                document.getElementById('lineItemsContainer').style.display = 'block';
            })
            .catch(error => {
                console.error('Ошибка:', error);
                alert('Ошибка при загрузке позиций комплектации');
            });
    }

    function renderLineItems(items) {
        console.log('DEBUG: Items received:', items);
        const tbody = document.getElementById('lineItemsBody');
        tbody.innerHTML = '';

        items.forEach((item, index) => {
            console.log(`DEBUG: Item ${index}:`, item);

            const row = document.createElement('tr');
            row.innerHTML = `
                <td>${item.chapter}</td>
                <td>${item.partName}</td>
                <td class="text-center"><strong>${item.requiredQuantity}</strong></td>
                <td class="text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <input type="number" class="form-control form-control-sm receipt-quantity"
                            id="receiptQty_${index}"
                            name="LineItems[${index}].ReceiptQuantity"
                            value="0"
                            min="0" max="9999"
                            style="width: 100px;" />
                        <button type="button" class="btn btn-md btn-outline-primary"
                            onclick="setRequiredQuantity(${index}, ${item.requiredQuantity})"
                            title="Заполнить требуемым количеством"
                            style="padding: 0.5rem 0.75rem; font-size: 0.95rem;">
                            <i class="fas fa-magic" style="font-size: 1.1rem;"></i>
                        </button>
                    </div>
                    <!-- Скрытые поля -->
                    <input type="hidden" name="LineItems[${index}].PositionId" value="${item.positionId}" />
                    <input type="hidden" name="LineItems[${index}].PartId" value="${item.partId}" />
                    <input type="hidden" name="LineItems[${index}].Chapter" value="${item.chapter}" />
                    <input type="hidden" name="LineItems[${index}].PartName" value="${item.partName}" />
                    <input type="hidden" name="LineItems[${index}].RequiredQuantity" value="${item.requiredQuantity}" />
                </td>
            `;
            tbody.appendChild(row);
        });
        // Показываем таблицу
        document.getElementById('lineItemsContainer').style.display = 'block';
    }

    // Функция для установки требуемого количества
    function setRequiredQuantity(index, requiredQuantity) {
        const input = document.getElementById(`receiptQty_${index}`);
        if (input) {
            input.value = requiredQuantity;
            input.classList.add('bg-light'); // Визуальная индикация изменения
            setTimeout(() => input.classList.remove('bg-light'), 500);
        }
    }

    // Обработка submit формы
    document.getElementById('receiptForm').addEventListener('submit', function(e) {
        e.preventDefault();
        this.submit();
    });

</script>

<style>
    .form-select-lg {
        padding: 0.5rem 1rem;
        font-size: 1.1rem;
    }

    .table-responsive {
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    input[type="number"] {
        text-align: center;
        font-weight: bold;
    }

    /* Стили для кнопки "Заполнить требуемым" */
    .btn-outline-primary {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }

    .btn-outline-primary:hover {
        background-color: #0d6efd;
        color: white;
    }

    /* Анимация подсветки */
    @@keyframes highlight {
        0% { background-color: #f8f9fa; }
        50% { background-color: #e9ecef; }
        100% { background-color: #f8f9fa; }
    }

    .bg-light {
        animation: highlight 0.5s ease;
    }
</style>
