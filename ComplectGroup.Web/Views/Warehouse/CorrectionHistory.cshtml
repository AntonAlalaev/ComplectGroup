@model List<CorrectionTransactionDto>

@{
    ViewData["Title"] = "История корректировок";
    var pagination = ViewBag.Pagination as ComplectGroup.Web.Models.PaginationInfo;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>📋 История корректировок пересортицы</h1>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <a asp-action="Correction" class="btn btn-primary">
                <i class="fas fa-plus"></i> Новая корректировка
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-warehouse"></i> Назад на склад
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Номер</th>
                        <th>Дата</th>
                        <th>Старая деталь</th>
                        <th>Новая деталь</th>
                        <th class="text-center">Количество</th>
                        <th>Примечания</th>
                        <th>Кто выполнил</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var correction in Model)
                    {
                        <tr>
                            <td><strong>@correction.CorrectionNumber</strong></td>
                            <td>@correction.CorrectionDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>[@correction.OldPart.Chapter.Name] @correction.OldPart.Name</td>
                            <td>[@correction.NewPart.Chapter.Name] @correction.NewPart.Name</td>
                            <td class="text-center">
                                <span class="badge bg-primary">@correction.Quantity</span>
                            </td>
                            <td>@correction.Notes</td>
                            <td><span class="badge bg-info text-dark">👤 @correction.CreatedBy</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Пагинация -->
        @if (pagination != null && pagination.TotalPages > 1)
        {
            <nav aria-label="Пагинация">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(pagination.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="CorrectionHistory" asp-route-pageNumber="@(pagination.CurrentPage - 1)">← Назад</a>
                    </li>
                    @for (var i = 1; i <= pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == pagination.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="CorrectionHistory" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(pagination.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="CorrectionHistory" asp-route-pageNumber="@(pagination.CurrentPage + 1)">Вперёд →</a>
                    </li>
                </ul>
            </nav>
            <p class="text-center text-muted">
                Страница @pagination.CurrentPage из @pagination.TotalPages (всего записей: @pagination.TotalItems)
            </p>
        }
        else
        {
            <div class="mt-3">
                <p class="text-muted">Всего корректировок: <strong>@Model.Count</strong></p>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Нет записей о корректировках
        </div>
    }
</div>